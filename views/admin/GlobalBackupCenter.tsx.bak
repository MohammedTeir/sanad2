import React, { useState, useEffect } from 'react';
import { realDataService } from '../../services/realDataServiceBackend';
import { makeAuthenticatedRequest } from '../../utils/apiUtils';
import Toast from '../../components/Toast';
import ConfirmModal from '../../components/ConfirmModal';

interface BackupOperation {
  id: string;
  operationType: 'backup' | 'sync' | 'restore';
  scope: 'full' | 'partial' | 'camp_specific';
  campId?: string;
  campName?: string;
  name?: string;
  fileName?: string;
  fileUrl?: string;
  status: 'processing' | 'completed' | 'failed';
  sizeBytes?: number;
  initiatedBy?: string;
  initiatedByName?: string;
  startedAt: string;
  completedAt?: string;
}

const GlobalBackupCenter = () => {
  const [backups, setBackups] = useState<BackupOperation[]>([]);
  const [loading, setLoading] = useState(true);
  const [refreshing, setRefreshing] = useState(false);
  const [toast, setToast] = useState<{ message: string; type: 'success' | 'error' | 'info' | 'warning' } | null>(null);

  const [showCreateModal, setShowCreateModal] = useState(false);
  const [creatingBackup, setCreatingBackup] = useState(false);
  const [backupType, setBackupType] = useState<'كامل' | 'جزئي' | 'خاص بالمخيم'>('كامل');
  const [selectedCampId, setSelectedCampId] = useState<string>('');
  const [backupName, setBackupName] = useState<string>('');
  const [camps, setCamps] = useState<any[]>([]);

  const [stats, setStats] = useState({
    total: 0,
    completed: 0,
    processing: 0,
    failed: 0,
    totalSize: 0
  });

  const [showRestoreConfirm, setShowRestoreConfirm] = useState(false);
  const [showDeleteConfirm, setShowDeleteConfirm] = useState(false);
  const [selectedBackup, setSelectedBackup] = useState<BackupOperation | null>(null);

  useEffect(() => {
    window.scrollTo(0, 0);
  }, []);

  const loadBackups = async () => {
    setLoading(true);
    setRefreshing(true);
    try {
      const response = await realDataService.getBackups();
      const backupData = Array.isArray(response) ? response : (response.data || []);
      setBackups(backupData);

      setStats({
        total: backupData.length,
        completed: backupData.filter((b: any) => b.status === 'completed').length,
        processing: backupData.filter((b: any) => b.status === 'processing').length,
        failed: backupData.filter((b: any) => b.status === 'failed').length,
        totalSize: backupData.reduce((sum: number, b: any) => sum + (parseFloat(b.size_bytes) || 0), 0)
      });
    } catch (err) {
      console.error('Error loading backups:', err);
    } finally {
      setLoading(false);
      setRefreshing(false);
    }
  };

  const loadCamps = async () => {
    try {
      const response = await realDataService.getCamps();
      setCamps(Array.isArray(response) ? response : []);
    } catch (err) {
      console.error('Error loading camps:', err);
    }
  };

  useEffect(() => {
    loadBackups();
    loadCamps();
  }, []);

  const handleRefresh = () => {
    loadBackups();
    setToast({ message: 'جاري تحديث البيانات...', type: 'info' });
  };

  const handleCreateBackup = async () => {
    setCreatingBackup(true);
    try {
      await makeAuthenticatedRequest('/backups', {
        method: 'POST',
        body: JSON.stringify({
          name: backupName || `نسخة احتياطية ${new Date().toLocaleDateString('ar-EG')}`,
          type: backupType,
          campId: backupType === 'خاص بالمخيم' ? selectedCampId : undefined
        })
      });

      setToast({ message: 'تم إنشاء النسخة الاحتياطية بنجاح', type: 'success' });
      setShowCreateModal(false);
      setBackupName('');
      setBackupType('كامل');
      setSelectedCampId('');
      loadBackups();
    } catch (err) {
      console.error('Error creating backup:', err);
      setToast({ message: 'فشل إنشاء النسخة الاحتياطية', type: 'error' });
    } finally {
      setCreatingBackup(false);
    }
  };

  const handleRestore = async () => {
    if (!selectedBackup) return;

    try {
      await makeAuthenticatedRequest(`/backups/${selectedBackup.id}/restore`, {
        method: 'POST'
      });

      setToast({ message: 'تمت استعادة النسخة الاحتياطية بنجاح', type: 'success' });
      setShowRestoreConfirm(false);
      setSelectedBackup(null);
      loadBackups();
    } catch (err) {
      console.error('Error restoring backup:', err);
      setToast({ message: 'فشل استعادة النسخة الاحتياطية', type: 'error' });
    }
  };

  const handleDelete = async () => {
    if (!selectedBackup) return;

    try {
      await makeAuthenticatedRequest(`/backups/${selectedBackup.id}`, {
        method: 'DELETE'
      });

      setToast({ message: 'تم حذف النسخة الاحتياطية بنجاح', type: 'success' });
      setShowDeleteConfirm(false);
      setSelectedBackup(null);
      loadBackups();
    } catch (err) {
      console.error('Error deleting backup:', err);
      setToast({ message: 'فشل حذف النسخة الاحتياطية', type: 'error' });
    }
  };

  const formatSize = (bytes: number) => {
    if (bytes === 0) return '0 Bytes';
    const k = 1024;
    const sizes = ['Bytes', 'KB', 'MB', 'GB'];
    const i = Math.floor(Math.log(bytes) / Math.log(k));
    return Math.round((bytes / Math.pow(k, i)) * 100) / 100 + ' ' + sizes[i];
  };

  if (loading) {
    return (
      <div className="min-h-screen bg-gray-50 flex items-center justify-center">
        <div className="text-center">
          <div className="animate-spin rounded-full h-16 w-16 border-t-4 border-b-4 border-emerald-500 mx-auto mb-4"></div>
          <p className="text-gray-600 font-bold">جاري التحميل...</p>
        </div>
      </div>
    );
  }

  return (
    <div className="min-h-screen bg-gray-50 p-4 md:p-6 lg:p-8">
      {toast && (
        <Toast message={toast.message} type={toast.type} onClose={() => setToast(null)} />
      )}

      <div className="max-w-7xl mx-auto">
        <div className="bg-white rounded-[2rem] border-2 border-gray-100 shadow-sm p-6 mb-6">
          <div className="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
            <div>
              <h1 className="text-2xl font-black text-gray-800 flex items-center gap-3">
                <div className="w-10 h-10 bg-emerald-600 text-white rounded-xl flex items-center justify-center">
                  <svg className="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M5 19a2 2 0 01-2-2V7a2 2 0 012-2h4l2 2h4a2 2 0 012 2v1M5 19h14a2 2 0 002-2v-5a2 2 0 00-2-2H9a2 2 0 00-2 2v5a2 2 0 01-2 2z" />
                    <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M9 17h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                  </svg>
                </div>
                مركز النسخ الاحتياطي
              </h1>
              <p className="text-gray-500 text-sm font-bold mt-1 mr-12">إدارة النسخ الاحتياطية والاستعادة للمظام</p>
            </div>
            <button
              onClick={() => setShowCreateModal(true)}
              className="flex items-center gap-2 px-6 py-3 bg-emerald-600 text-white rounded-xl font-bold shadow-lg hover:bg-emerald-700 transition-all"
            >
              <svg className="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M12 4v16m8-8H4" />
              </svg>
              نسخة جديدة
            </button>
          </div>

          <div className="grid grid-cols-1 sm:grid-cols-5 gap-4 mt-6 pt-6 border-t">
            <div className="bg-blue-50 rounded-2xl p-4 text-center">
              <p className="text-3xl font-black text-blue-600">{stats.total}</p>
              <p className="text-xs font-bold text-blue-700 mt-1">إجمالي النسخ</p>
            </div>
            <div className="bg-emerald-50 rounded-2xl p-4 text-center">
              <p className="text-3xl font-black text-emerald-600">{stats.completed}</p>
              <p className="text-xs font-bold text-emerald-700 mt-1">مكتملة</p>
            </div>
            <div className="bg-amber-50 rounded-2xl p-4 text-center">
              <p className="text-3xl font-black text-amber-600">{stats.processing}</p>
              <p className="text-xs font-bold text-amber-700 mt-1">جاري المعالجة</p>
            </div>
            <div className="bg-red-50 rounded-2xl p-4 text-center">
              <p className="text-3xl font-black text-red-600">{stats.failed}</p>
              <p className="text-xs font-bold text-red-700 mt-1">فشل</p>
            </div>
            <div className="bg-purple-50 rounded-2xl p-4 text-center">
              <p className="text-2xl font-black text-purple-600">{formatSize(stats.totalSize)}</p>
              <p className="text-xs font-bold text-purple-700 mt-1">الحجم الإجمالي</p>
            </div>
          </div>
        </div>

        <div className="bg-white rounded-[2rem] border-2 border-gray-100 shadow-sm overflow-hidden">
          <div className="overflow-x-auto">
            <table className="w-full">
              <thead className="bg-gray-50 border-b-2 border-gray-100">
                <tr>
                  <th className="px-6 py-4 text-right text-xs font-black text-gray-500 uppercase tracking-wider">اسم النسخة</th>
                  <th className="px-6 py-4 text-right text-xs font-black text-gray-500 uppercase tracking-wider">النوع</th>
                  <th className="px-6 py-4 text-right text-xs font-black text-gray-500 uppercase tracking-wider">النطاق</th>
                  <th className="px-6 py-4 text-center text-xs font-black text-gray-500 uppercase tracking-wider">الحالة</th>
                  <th className="px-6 py-4 text-center text-xs font-black text-gray-500 uppercase tracking-wider">الحجم</th>
                  <th className="px-6 py-4 text-center text-xs font-black text-gray-500 uppercase tracking-wider">الإجراءات</th>
                </tr>
              </thead>
              <tbody className="divide-y divide-gray-50">
                {backups.length > 0 ? backups.map((backup) => (
                  <tr key={backup.id} className="hover:bg-gray-50 transition-colors">
                    <td className="px-6 py-4">
                      <div>
                        <p className="font-black text-gray-800 text-sm">{backup.name || backup.fileName || 'نسخة احتياطية'}</p>
                        <p className="text-xs text-gray-500 font-bold mt-1">
                          {new Date(backup.startedAt).toLocaleDateString('ar-EG', {
                            year: 'numeric',
                            month: 'short',
                            day: 'numeric',
                            hour: '2-digit',
                            minute: '2-digit'
                          })}
                        </p>
                      </div>
                    </td>
                    <td className="px-6 py-4">
                      <span className={`inline-block px-3 py-1 rounded-lg font-black text-xs border-2 ${
                        backup.operationType === 'backup' ? 'bg-blue-100 text-blue-700 border-blue-200' :
                        backup.operationType === 'sync' ? 'bg-purple-100 text-purple-700 border-purple-200' :
                        'bg-amber-100 text-amber-700 border-amber-200'
                      }`}>
                        {backup.operationType === 'backup' ? 'نسخ احتياطي' :
                         backup.operationType === 'sync' ? 'مزامنة' :
                         'استعادة'}
                      </span>
                    </td>
                    <td className="px-6 py-4">
                      <span className="inline-block px-3 py-1 rounded-lg font-black text-xs border-2 bg-gray-100 text-gray-700">
                        {backup.scope === 'full' ? 'كامل' :
                         backup.scope === 'partial' ? 'جزئي' :
                         backup.campName || 'مخيم محدد'}
                      </span>
                    </td>
                    <td className="px-6 py-4 text-center">
                      <span className={`inline-block px-3 py-1 rounded-lg font-black text-xs border-2 ${
                        backup.status === 'completed' ? 'bg-emerald-100 text-emerald-700 border-emerald-200' :
                        backup.status === 'processing' ? 'bg-blue-100 text-blue-700 border-blue-200' :
                        'bg-red-100 text-red-700 border-red-200'
                      }`}>
                        {backup.status === 'completed' ? 'مكتمل' :
                         backup.status === 'processing' ? 'جاري المعالجة' :
                         'فشل'}
                      </span>
                    </td>
                    <td className="px-6 py-4 text-center">
                      <span className="text-sm font-bold text-gray-700">
                        {formatSize(backup.sizeBytes || 0)}
                      </span>
                    </td>
                    <td className="px-6 py-4">
                      <div className="flex items-center justify-center gap-2">
                        {backup.status === 'completed' && (
                          <>
                            <button
                              onClick={() => {
                                setSelectedBackup(backup);
                                setShowRestoreConfirm(true);
                              }}
                              className="px-3 py-1.5 bg-emerald-100 text-emerald-700 rounded-lg font-bold text-xs hover:bg-emerald-200 transition-all"
                            >
                              استعادة
                            </button>
                            <button
                              onClick={() => window.open(backup.fileUrl, '_blank')}
                              className="px-3 py-1.5 bg-blue-100 text-blue-700 rounded-lg font-bold text-xs hover:bg-blue-200 transition-all"
                            >
                              تحميل
                            </button>
                          </>
                        )}
                        <button
                          onClick={() => {
                            setSelectedBackup(backup);
                            setShowDeleteConfirm(true);
                          }}
                          className="px-3 py-1.5 bg-red-100 text-red-700 rounded-lg font-bold text-xs hover:bg-red-200 transition-all"
                        >
                          حذف
                        </button>
                      </div>
                    </td>
                  </tr>
                )) : (
                  <tr>
                    <td colSpan={6} className="px-6 py-12 text-center">
                      <div className="w-16 h-16 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-4">
                        <svg className="w-8 h-8 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4" />
                        </svg>
                      </div>
                      <p className="text-gray-500 font-bold">لا توجد نسخ احتياطية</p>
                    </td>
                  </tr>
                )}
              </tbody>
            </table>
          </div>
        </div>
      </div>

      {showCreateModal && (
        <div className="fixed inset-0 bg-black/60 z-50 flex items-center justify-center p-4">
          <div className="bg-white rounded-[2rem] p-8 max-w-md w-full">
            <div className="flex items-center justify-between mb-6">
              <h2 className="text-2xl font-black text-gray-800">إنشاء نسخة احتياطية</h2>
              <button
                onClick={() => setShowCreateModal(false)}
                className="w-10 h-10 bg-gray-100 rounded-xl flex items-center justify-center hover:bg-gray-200 transition-all"
              >
                <svg className="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M6 18L18 6M6 6l12 12" />
                </svg>
              </button>
            </div>

            <div className="space-y-4">
              <div>
                <label className="block text-xs font-black text-gray-700 mb-2 uppercase">اسم النسخة (اختياري)</label>
                <input
                  type="text"
                  value={backupName}
                  onChange={(e) => setBackupName(e.target.value)}
                  placeholder="نسخة احتياطية ليوم..."
                  className="w-full p-4 bg-gray-50 border-2 border-gray-100 rounded-2xl focus:border-emerald-500 focus:outline-none font-bold text-sm"
                />
              </div>

              <div>
                <label className="block text-xs font-black text-gray-700 mb-2 uppercase">نوع النسخة</label>
                <div className="grid grid-cols-3 gap-3">
                  {(['كامل', 'جزئي', 'خاص بالمخيم'] as const).map((type) => (
                    <button
                      key={type}
                      onClick={() => setBackupType(type)}
                      className={`p-4 rounded-2xl font-black text-sm transition-all ${
                        backupType === type
                          ? 'bg-emerald-600 text-white shadow-lg'
                          : 'bg-gray-100 text-gray-600 hover:bg-gray-200'
                      }`}
                    >
                      {type}
                    </button>
                  ))}
                </div>
              </div>

              {backupType === 'خاص بالمخيم' && (
                <div>
                  <label className="block text-xs font-black text-gray-700 mb-2 uppercase">اختر المخيم</label>
                  <select
                    value={selectedCampId}
                    onChange={(e) => setSelectedCampId(e.target.value)}
                    className="w-full p-4 bg-gray-50 border-2 border-gray-100 rounded-2xl focus:border-emerald-500 focus:outline-none font-bold text-sm"
                  >
                    <option value="">اختر المخيم...</option>
                    {camps.map(camp => (
                      <option key={camp.id} value={camp.id}>{camp.name}</option>
                    ))}
                  </select>
                </div>
              )}

              <div className="flex gap-3 pt-4">
                <button
                  onClick={() => setShowCreateModal(false)}
                  className="flex-1 px-6 py-3 bg-gray-100 text-gray-700 rounded-xl font-black hover:bg-gray-200 transition-all"
                >
                  إلغاء
                </button>
                <button
                  onClick={handleCreateBackup}
                  disabled={creatingBackup || (backupType === 'خاص بالمخيم' && !selectedCampId)}
                  className="flex-1 px-6 py-3 bg-emerald-600 text-white rounded-xl font-black hover:bg-emerald-700 transition-all disabled:opacity-50"
                >
                  {creatingBackup ? 'جاري الإنشاء...' : 'إنشاء'}
                </button>
              </div>
            </div>
          </div>
        </div>
      )}

      {showRestoreConfirm && selectedBackup && (
        <ConfirmModal
          isOpen={showRestoreConfirm}
          onClose={() => setShowRestoreConfirm(false)}
          onConfirm={handleRestore}
          title="تأكيد الاستعادة"
          message={
            <div className="space-y-3">
              <p className="font-bold text-gray-700">
                هل أنت متأكد من استعادة النسخة الاحتياطية <span className="text-emerald-600">"{selectedBackup.name || selectedBackup.fileName}"</span>؟
              </p>
              <p className="text-sm text-amber-600 font-bold">
                تحذير: سيتم استبدال البيانات الحالية بالبيانات من النسخة الاحتياطية.
              </p>
            </div>
          }
          confirmText="نعم، استعادة"
          cancelText="إلغاء"
          type="warning"
          isLoading={false}
        />
      )}

      {showDeleteConfirm && selectedBackup && (
        <ConfirmModal
          isOpen={showDeleteConfirm}
          onClose={() => setShowDeleteConfirm(false)}
          onConfirm={handleDelete}
          title="تأكيد الحذف"
          message={
            <div className="space-y-3">
              <p className="font-bold text-gray-700">
                هل أنت متأكد من حذف النسخة الاحتياطية <span className="text-red-600">"{selectedBackup.name || selectedBackup.fileName}"</span>؟
              </p>
              <p className="text-sm text-red-600 font-bold">
                تحذير: لا يمكن التراجع عن هذا الإجراء.
              </p>
            </div>
          }
          confirmText="نعم، حذف"
          cancelText="إلغاء"
          type="danger"
          isLoading={false}
        />
      )}
    </div>
  );
};

export default GlobalBackupCenter;
