// views/camp-manager/TransferRequests.tsx
import React, { useState, useEffect, useCallback } from 'react';
import { realDataService } from '../../services/realDataServiceBackend';
import { sessionService } from '../../services/sessionService';
import Toast from '../../components/Toast';
import ConfirmModal from '../../components/ConfirmModal';

interface TransferRequest {
  id: string;
  dp_id: string;
  dp_name: string;
  dp_national_id?: string;
  dp_phone?: string;
  from_camp_id: string;
  from_camp_name: string;
  to_camp_id: string;
  to_camp_name: string;
  status: 'قيد الانتظار' | 'موافق' | 'مرفوض' | 'تمت المعالجة';
  request_date: string;
  reason: string;
  additional_notes?: string;
  reviewed_by?: string;
  reviewed_at?: string;
  rejection_reason?: string;
  admin_notes?: string;
  family_members_count?: number;
}

const TransferRequests: React.FC = () => {
  const [requests, setRequests] = useState<TransferRequest[]>([]);
  const [loading, setLoading] = useState(true);
  const [refreshing, setRefreshing] = useState(false);
  const [toast, setToast] = useState<{ message: string; type: 'success' | 'error' | 'info' | 'warning' } | null>(null);
  const [activeTab, setActiveTab] = useState<'incoming' | 'outgoing' | 'history'>('incoming');
  const [showApproveModal, setShowApproveModal] = useState(false);
  const [showRejectModal, setShowRejectModal] = useState(false);
  const [selectedRequest, setSelectedRequest] = useState<TransferRequest | null>(null);
  const [rejectionReason, setRejectionReason] = useState('');
  const [currentCampId, setCurrentCampId] = useState<string>('');

  useEffect(() => {
    window.scrollTo(0, 0);
    const currentUser = sessionService.getCurrentUser();
    if (currentUser?.campId) {
      setCurrentCampId(currentUser.campId);
    } else {
      setToast({ message: 'لم يتم تحديد المخيم', type: 'error' });
      setLoading(false);
    }
  }, []);

  useEffect(() => {
    if (toast) {
      const timer = setTimeout(() => setToast(null), 5000);
      return () => clearTimeout(timer);
    }
  }, [toast]);

  const loadRequests = useCallback(async () => {
    try {
      setLoading(true);
      if (!currentCampId) return;

      const allRequests = await realDataService.getTransferRequests();
      const incoming = allRequests.filter((r: TransferRequest) => r.to_camp_id === currentCampId);
      const outgoing = allRequests.filter((r: TransferRequest) => r.from_camp_id === currentCampId);

      setRequests(activeTab === 'incoming' ? incoming : outgoing);
    } catch (err: any) {
      console.error('Error loading transfer requests:', err);
      setToast({ message: 'فشل تحميل طلبات النقل', type: 'error' });
    } finally {
      setLoading(false);
      setRefreshing(false);
    }
  }, [currentCampId, activeTab]);

  useEffect(() => {
    if (currentCampId) loadRequests();
  }, [currentCampId, activeTab, loadRequests]);

  const handleRefresh = () => {
    setRefreshing(true);
    loadRequests();
    setToast({ message: 'جاري تحديث البيانات...', type: 'info' });
  };

  const handleApprove = async () => {
    if (!selectedRequest) return;

    try {
      await realDataService.updateTransferRequest(selectedRequest.id, {
        status: 'موافق',
        admin_notes: 'تمت الموافقة على طلب النقل'
      });

      setToast({ message: 'تمت الموافقة على طلب النقل بنجاح', type: 'success' });
      setShowApproveModal(false);
      setSelectedRequest(null);
      loadRequests();
    } catch (err: any) {
      console.error('Error approving request:', err);
      setToast({ message: 'فشل الموافقة على طلب النقل', type: 'error' });
    }
  };

  const handleReject = async () => {
    if (!selectedRequest) return;

    try {
      await realDataService.updateTransferRequest(selectedRequest.id, {
        status: 'مرفوض',
        rejection_reason: rejectionReason || 'غير محدد'
      });

      setToast({ message: 'تم رفض طلب النقل', type: 'success' });
      setShowRejectModal(false);
      setSelectedRequest(null);
      setRejectionReason('');
      loadRequests();
    } catch (err: any) {
      console.error('Error rejecting request:', err);
      setToast({ message: 'فشل رفض طلب النقل', type: 'error' });
    }
  };

  const incomingRequests = requests.filter(r => r.to_camp_id === currentCampId);
  const outgoingRequests = requests.filter(r => r.from_camp_id === currentCampId);
  const pendingCount = incomingRequests.filter(r => r.status === 'قيد الانتظار').length;

  if (loading) {
    return (
      <div className="min-h-screen bg-gray-50 flex items-center justify-center">
        <div className="text-center">
          <div className="animate-spin rounded-full h-16 w-16 border-t-4 border-b-4 border-emerald-500 mx-auto mb-4"></div>
          <p className="text-gray-600 font-bold">جاري التحميل...</p>
        </div>
      </div>
    );
  }

  return (
    <div className="min-h-screen bg-gray-50 p-4 md:p-6 lg:p-8">
      {toast && (
        <Toast
          message={toast.message}
          type={toast.type}
          onClose={() => setToast(null)}
        />
      )}

      <div className="max-w-7xl mx-auto">
        {/* Header */}
        <div className="bg-white rounded-[2rem] border-2 border-gray-100 shadow-sm p-6 mb-6">
          <div className="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
            <div>
              <h1 className="text-2xl font-black text-gray-800 flex items-center gap-3">
                <div className="w-10 h-10 bg-emerald-600 text-white rounded-xl flex items-center justify-center">
                  <svg className="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />
                  </svg>
                </div>
                طلبات النقل
              </h1>
              <p className="text-gray-500 text-sm font-bold mt-1 mr-12">إدارة طلبات نقل الأسر بين المخيمات</p>
            </div>
          </div>

          {/* Tabs */}
          <div className="flex gap-2 mt-6 overflow-x-auto">
            <button
              onClick={() => setActiveTab('incoming')}
              className={`px-6 py-3 rounded-xl font-black text-sm whitespace-nowrap transition-all ${
                activeTab === 'incoming'
                  ? 'bg-emerald-600 text-white shadow-lg'
                  : 'bg-gray-100 text-gray-600 hover:bg-gray-200'
              }`}
            >
              📥 الواردة ({incomingRequests.length})
            </button>
            <button
              onClick={() => setActiveTab('outgoing')}
              className={`px-6 py-3 rounded-xl font-black text-sm whitespace-nowrap transition-all ${
                activeTab === 'outgoing'
                  ? 'bg-emerald-600 text-white shadow-lg'
                  : 'bg-gray-100 text-gray-600 hover:bg-gray-200'
              }`}
            >
              📤 الصادرة ({outgoingRequests.length})
            </button>
            <button
              onClick={() => setActiveTab('history')}
              className={`px-6 py-3 rounded-xl font-black text-sm whitespace-nowrap transition-all ${
                activeTab === 'history'
                  ? 'bg-emerald-600 text-white shadow-lg'
                  : 'bg-gray-100 text-gray-600 hover:bg-gray-200'
              }`}
            >
              📋 السجل ({requests.filter(r => r.status !== 'قيد الانتظار').length})
            </button>
          </div>
        </div>

        {/* Requests List */}
        <div className="bg-white rounded-[2rem] border-2 border-gray-100 shadow-sm overflow-hidden">
          <div className="overflow-x-auto">
            <table className="w-full">
              <thead className="bg-gray-50 border-b-2 border-gray-100">
                <tr>
                  <th className="px-6 py-4 text-right text-xs font-black text-gray-500 uppercase tracking-wider">الأسرة</th>
                  <th className="px-6 py-4 text-right text-xs font-black text-gray-500 uppercase tracking-wider">من</th>
                  <th className="px-6 py-4 text-right text-xs font-black text-gray-500 uppercase tracking-wider">إلى</th>
                  <th className="px-6 py-4 text-center text-xs font-black text-gray-500 uppercase tracking-wider">تاريخ الطلب</th>
                  <th className="px-6 py-4 text-center text-xs font-black text-gray-500 uppercase tracking-wider">الحالة</th>
                  <th className="px-6 py-4 text-center text-xs font-black text-gray-500 uppercase tracking-wider">الإجراءات</th>
                </tr>
              </thead>
              <tbody className="divide-y divide-gray-50">
                {requests.length > 0 ? requests.map((req) => (
                  <tr key={req.id} className="hover:bg-gray-50 transition-colors">
                    <td className="px-6 py-4">
                      <div>
                        <p className="font-black text-gray-800 text-sm">{req.dp_name || 'غير معروف'}</p>
                        <p className="text-xs text-gray-500 font-bold mt-1">
                          {req.family_members_count || 0} أفراد
                        </p>
                      </div>
                    </td>
                    <td className="px-6 py-4">
                      <p className="font-bold text-gray-700 text-sm">{req.from_camp_name}</p>
                    </td>
                    <td className="px-6 py-4">
                      <p className="font-bold text-gray-700 text-sm">{req.to_camp_name}</p>
                    </td>
                    <td className="px-6 py-4 text-center">
                      <span className="text-sm font-bold text-gray-600">
                        {new Date(req.request_date).toLocaleDateString('ar-EG', {
                          year: 'numeric',
                          month: 'short',
                          day: 'numeric'
                        })}
                      </span>
                    </td>
                    <td className="px-6 py-4 text-center">
                      <span className={`inline-block px-3 py-1 rounded-lg font-black text-xs border-2 ${
                        req.status === 'قيد الانتظار' ? 'bg-amber-100 text-amber-700 border-amber-200' :
                        req.status === 'موافق' ? 'bg-emerald-100 text-emerald-700 border-emerald-200' :
                        req.status === 'مرفوض' ? 'bg-red-100 text-red-700 border-red-200' :
                        'bg-gray-100 text-gray-700 border-gray-200'
                      }`}>
                        {req.status}
                      </span>
                    </td>
                    <td className="px-6 py-4">
                      <div className="flex items-center justify-center gap-2">
                        {req.status === 'قيد الانتظار' && activeTab === 'incoming' && (
                          <>
                            <button
                              onClick={() => {
                                setSelectedRequest(req);
                                setShowApproveModal(true);
                              }}
                              className="px-3 py-1.5 bg-emerald-100 text-emerald-700 rounded-lg font-bold text-xs hover:bg-emerald-200 transition-all"
                            >
                              موافقة
                            </button>
                            <button
                              onClick={() => {
                                setSelectedRequest(req);
                                setShowRejectModal(true);
                              }}
                              className="px-3 py-1.5 bg-red-100 text-red-700 rounded-lg font-bold text-xs hover:bg-red-200 transition-all"
                            >
                              رفض
                            </button>
                          </>
                        )}
                        <button
                          onClick={() => window.location.href = `/manager/dp-details/${req.dp_id}`}
                          className="px-3 py-1.5 bg-blue-100 text-blue-700 rounded-lg font-bold text-xs hover:bg-blue-200 transition-all"
                        >
                          عرض
                        </button>
                      </div>
                    </td>
                  </tr>
                )) : (
                  <tr>
                    <td colSpan={6} className="px-6 py-12 text-center">
                      <div className="w-16 h-16 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-4">
                        <svg className="w-8 h-8 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4" />
                        </svg>
                      </div>
                      <p className="text-gray-500 font-bold">
                        {activeTab === 'incoming' ? 'لا توجد طلبات واردة حالياً' :
                         activeTab === 'outgoing' ? 'لا توجد طلبات صادرة حالياً' :
                         'لا توجد طلبات في السجل'}
                      </p>
                    </td>
                  </tr>
                )}
              </tbody>
            </table>
          </div>
        </div>
      </div>

      {/* Approve Modal */}
      {showApproveModal && selectedRequest && (
        <ConfirmModal
          isOpen={showApproveModal}
          onClose={() => setShowApproveModal(false)}
          onConfirm={handleApprove}
          title="تأكيد الموافقة"
          message={
            <div className="space-y-3">
              <p className="font-bold text-gray-700">
                هل أنت متأكد من الموافقة على طلب نقل أسرة <span className="text-emerald-600">"{selectedRequest.dp_name}"</span>؟
              </p>
              <p className="text-sm text-gray-500 font-bold">
                من {selectedRequest.from_camp_name} إلى {selectedRequest.to_camp_name}
              </p>
            </div>
          }
          confirmText="نعم، موافقة"
          cancelText="إلغاء"
          type="success"
          isLoading={false}
        />
      )}

      {/* Reject Modal */}
      {showRejectModal && selectedRequest && (
        <ConfirmModal
          isOpen={showRejectModal}
          onClose={() => {
            setShowRejectModal(false);
            setRejectionReason('');
          }}
          onConfirm={handleReject}
          title="تأكيد الرفض"
          message={
            <div className="space-y-3">
              <p className="font-bold text-gray-700">
                هل أنت متأكد من رفض طلب نقل أسرة <span className="text-red-600">"{selectedRequest.dp_name}"</span>؟
              </p>
              <div>
                <label className="block text-sm font-bold text-gray-700 mb-2">سبب الرفض</label>
                <textarea
                  value={rejectionReason}
                  onChange={(e) => setRejectionReason(e.target.value)}
                  placeholder="اكتب سبب الرفض..."
                  className="w-full p-3 rounded-xl border-2 border-gray-200 focus:border-red-500 focus:outline-none font-bold text-sm"
                  rows={3}
                />
              </div>
            </div>
          }
          confirmText="نعم، رفض"
          cancelText="إلغاء"
          type="danger"
          isLoading={false}
        />
      )}
    </div>
  );
};

export default TransferRequests;
