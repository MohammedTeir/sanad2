interface DPPortalProps {
  profileId: string;
  onLogout: () => void;
}

const DPPortal: React.FC<DPPortalProps> = ({ profileId, onLogout }) => {
  const navigate = useNavigate();
  const [dp, setDp] = useState<DPProfileExtended | null>(null);
  const [familyMembers, setFamilyMembers] = useState<FamilyMember[]>([]);
  const [loading, setLoading] = useState(true);
  const [toast, setToast] = useState<{ message: string; type: 'success' | 'error' | 'info' | 'warning' } | null>(null);
  const [activeTab, setActiveTab] = useState<'basic' | 'family' | 'housing' | 'health' | 'spouse' | 'documents' | 'emergency' | 'updates' | 'complaints'>('basic');

  // Data states
  const [emergencyReports, setEmergencyReports] = useState<EmergencyReport[]>([]);
  const [updateRequests, setUpdateRequests] = useState<UpdateRequest[]>([]);
  const [complaints, setComplaints] = useState<Complaint[]>([]);

  // Modal states
  const [showEmergencyModal, setShowEmergencyModal] = useState(false);
  const [showUpdateModal, setShowUpdateModal] = useState(false);
  const [showComplaintModal, setShowComplaintModal] = useState(false);

  // Track loaded tabs to prevent re-fetching
  const [loadedTabs, setLoadedTabs] = useState<Set<string>>(new Set());

  useEffect(() => {
    window.scrollTo(0, 0);
    
    // Get familyId from current user token
    const currentUser = sessionService.getCurrentUser();
    console.log('[DPPortal] Current user:', currentUser);
    
    if (!currentUser?.familyId) {
      console.error('[DPPortal] No familyId found in user token');
      setToast({ 
        message: 'لم يتم العثور على معرف العائلة. يرجى تسجيل الدخول مرة أخرى.', 
        type: 'error' 
      });
      setLoading(false);
      return;
    }
    
    // Use familyId from token instead of profileId prop
    const actualFamilyId = currentUser.familyId;
    console.log('[DPPortal] Using familyId:', actualFamilyId);
    
    loadData(actualFamilyId);
  }, []);

  // Load tab-specific data when active tab changes
  useEffect(() => {
    if (activeTab !== 'basic' && activeTab !== 'family' && activeTab !== 'housing' && activeTab !== 'health' && activeTab !== 'spouse' && activeTab !== 'documents') {
      loadTabData(activeTab);
    }
  }, [activeTab]);

