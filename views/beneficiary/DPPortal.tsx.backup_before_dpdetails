// Beneficiary DP Details Portal - Read-only with Request-based Actions
// Features: Emergency Reports, Update Requests, Complaints
// Styled to match Campaign Manager pages pattern

import React, { useState, useEffect, useCallback } from 'react';
import { useNavigate } from 'react-router-dom';
import { beneficiaryService } from '../../services/beneficiaryService';
import { sessionService } from '../../services/sessionService';
import Toast from '../../components/Toast';
import { GAZA_LOCATIONS, getAreasByGovernorate } from '../../constants/gazaLocations';
import type { DPProfile, FamilyMember } from '../../types';

// Import forms
import EmergencyReportForm from './forms/EmergencyReportForm';
import UpdateRequestForm from './forms/UpdateRequestForm';
import ComplaintForm from './forms/ComplaintForm';

interface DPProfileExtended extends Omit<DPProfile, 'currentHousingDetailedType'> {
  // Flat fields for direct binding
  originalAddressGovernorate?: string;
  originalAddressRegion?: string;
  originalAddressDetails?: string;
  originalAddressHousingType?: string;
  currentHousingType?: string;
  currentHousingIsSuitable?: boolean;
  currentHousingSanitaryFacilities?: string;
  currentHousingWaterSource?: string;
  currentHousingElectricityAccess?: string;
  currentHousingGovernorate?: string;
  currentHousingRegion?: string;
  currentHousingLandmark?: string;
  currentHousingSharingStatus?: string;
  currentHousingDetailedType?: string; // Override with string for flexibility
  currentHousingFurnished?: boolean;
}

interface EmergencyReport {
  id: string;
  familyId: string;
  emergencyType: string;
  description: string;
  urgency: 'عاجل جداً' | 'عاجل' | 'عادي';
  location?: string;
  status: string;
  assignedTo?: string;
  resolvedAt?: string;
  resolutionNotes?: string;
  createdAt: string;
  updatedAt: string;
}

interface UpdateRequest {
  id: string;
  familyId: string;
  fieldName: string;
  oldValue?: string;
  newValue: string;
  reason: string;
  status: 'قيد الانتظار' | 'قيد المراجعة' | 'موافق' | 'مرفوض' | 'تم التطبيق';
  reviewedBy?: string;
  reviewedAt?: string;
  appliedAt?: string;
  createdAt: string;
}

interface Complaint {
  id: string;
  familyId: string;
  subject: string;
  description: string;
  category: string;
  isAnonymous: boolean;
  status: 'جديد' | 'قيد المراجعة' | 'تم الحل' | 'مرفوض';
  response?: string;
  respondedAt?: string;
  createdAt: string;
  updatedAt: string;
}

