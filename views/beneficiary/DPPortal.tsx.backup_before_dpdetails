    setLoading(true);
    try {
      console.log('[DPPortal] Loading data for familyId:', familyId);
      
      // Load profile and family members in parallel
      const [profileData, membersData] = await Promise.all([
        beneficiaryService.getFamilyProfile(familyId),
        beneficiaryService.getFamilyMembers(familyId)
      ]);

      console.log('[DPPortal] Profile data loaded:', profileData);

      // Transform snake_case to camelCase and nested objects to flat fields
      const flatData: DPProfileExtended = {
        ...profileData,
        // Basic fields from snake_case
        headOfFamily: (profileData as any).head_of_family_name || profileData.headOfFamily,
        nationalId: (profileData as any).head_of_family_national_id || profileData.nationalId,
        gender: (profileData as any).head_of_family_gender || profileData.gender,
        dateOfBirth: (profileData as any).head_of_family_date_of_birth || profileData.dateOfBirth,
        age: (profileData as any).head_of_family_age || profileData.age,
        maritalStatus: (profileData as any).head_of_family_marital_status || profileData.maritalStatus,
        widowReason: (profileData as any).head_of_family_widow_reason || profileData.widowReason,
        headRole: (profileData as any).head_of_family_role || profileData.headRole,
        phoneNumber: (profileData as any).head_of_family_phone_number || profileData.phoneNumber,
        phoneSecondary: (profileData as any).head_of_family_phone_secondary || profileData.phoneSecondary,
        totalMembersCount: (profileData as any).total_members_count || profileData.totalMembersCount,
        maleCount: (profileData as any).male_count || profileData.maleCount,
        femaleCount: (profileData as any).female_count || profileData.femaleCount,
        childCount: (profileData as any).child_count || profileData.childCount,
        teenagerCount: (profileData as any).teenager_count || profileData.teenagerCount,
        adultCount: (profileData as any).adult_count || profileData.adultCount,
        seniorCount: (profileData as any).senior_count || profileData.seniorCount,
        disabledCount: (profileData as any).disabled_count || profileData.disabledCount,
        injuredCount: (profileData as any).injured_count || profileData.injuredCount,
        pregnantWomenCount: (profileData as any).pregnant_women_count || profileData.pregnantWomenCount,
        vulnerabilityScore: (profileData as any).vulnerability_score || profileData.vulnerabilityScore,
        vulnerabilityPriority: (profileData as any).vulnerability_priority || profileData.vulnerabilityPriority,
        registrationStatus: (profileData as any).status || profileData.registrationStatus,
        // Wife fields
        wifeName: (profileData as any).wife_name || profileData.wifeName,
        wifeNationalId: (profileData as any).wife_national_id || profileData.wifeNationalId,
        wifeDateOfBirth: (profileData as any).wife_date_of_birth || profileData.wifeDateOfBirth,
        wifeAge: (profileData as any).wife_age || profileData.wifeAge,
        wifeIsPregnant: (profileData as any).wife_is_pregnant || profileData.wifeIsPregnant,
        wifePregnancyMonth: (profileData as any).wife_pregnancy_month || profileData.wifePregnancyMonth,
        wifePregnancySpecialNeeds: (profileData as any).wife_pregnancy_special_needs || profileData.wifePregnancySpecialNeeds,
        wifeIsWorking: (profileData as any).wife_is_working || profileData.wifeIsWorking,
        wifeOccupation: (profileData as any).wife_occupation || profileData.wifeOccupation,
        wifeDisabilityType: (profileData as any).wife_disability_type || profileData.wifeDisabilityType,
        wifeChronicDiseaseType: (profileData as any).wife_chronic_disease_type || profileData.wifeChronicDiseaseType,
        wifeWarInjuryType: (profileData as any).wife_war_injury_type || profileData.wifeWarInjuryType,
        // Housing fields
        originalAddressGovernorate: (profileData as any).original_address_governorate || profileData.originalAddress?.governorate,
        originalAddressRegion: (profileData as any).original_address_region || profileData.originalAddress?.region,
        originalAddressDetails: (profileData as any).original_address_details || profileData.originalAddress?.details,
        originalAddressHousingType: (profileData as any).original_address_housing_type || profileData.originalAddress?.housingType,
        currentHousingType: (profileData as any).current_housing_type || profileData.currentHousing?.type,
        currentHousingIsSuitable: (profileData as any).current_housing_is_suitable_for_family_size || profileData.currentHousing?.isSuitableForFamilySize,
        currentHousingSanitaryFacilities: (profileData as any).current_housing_sanitary_facilities || profileData.currentHousing?.sanitaryFacilities,
        currentHousingWaterSource: (profileData as any).current_housing_water_source || profileData.currentHousing?.waterSource,
        currentHousingElectricityAccess: (profileData as any).current_housing_electricity_access || profileData.currentHousing?.electricityAccess,
        currentHousingGovernorate: (profileData as any).current_housing_governorate || profileData.currentHousing?.governorate,
        currentHousingRegion: (profileData as any).current_housing_region || profileData.currentHousing?.region,
        currentHousingLandmark: (profileData as any).current_housing_landmark || profileData.currentHousing?.landmark,
        currentHousingSharingStatus: (profileData as any).current_housing_sharing_status || profileData.currentHousing?.sharingStatus,
        currentHousingDetailedType: (profileData as any).current_housing_detailed_type || profileData.currentHousing?.detailedType,
        currentHousingFurnished: (profileData as any).current_housing_furnished || profileData.currentHousing?.furnished,
        unitNumber: (profileData as any).current_housing_unit_number || profileData.unitNumber,
        // 4-part name structure
        headFirstName: (profileData as any).head_first_name || profileData.headFirstName,
        headFatherName: (profileData as any).head_father_name || profileData.headFatherName,
        headGrandfatherName: (profileData as any).head_grandfather_name || profileData.headGrandfatherName,
        headFamilyName: (profileData as any).head_family_name || profileData.headFamilyName
      };

      console.log('[DPPortal] Transformed flatData:', flatData);
      setDp(flatData);
      setFamilyMembers(membersData);
      setLoadedTabs(prev => new Set(prev).add('basic'));
    } catch (err: any) {
      console.error('[DPPortal] Error loading data:', err);
      console.error('[DPPortal] Error details:', err.message);
      console.error('[DPPortal] Full error:', JSON.stringify(err, null, 2));
      setToast({ message: err.message || 'فشل تحميل البيانات. يرجى المحاولة مرة أخرى.', type: 'error' });
    } finally {
      setLoading(false);
    }
  };

  const loadDP = async () => {
    try {
      const profileData = await beneficiaryService.getFamilyProfile(profileId);

      // Transform nested objects to flat fields for backward compatibility
      const flatData: DPProfileExtended = {
        ...profileData,
        originalAddressGovernorate: (profileData as any).original_address_governorate || profileData.originalAddress?.governorate,
        originalAddressRegion: (profileData as any).original_address_region || profileData.originalAddress?.region,
        originalAddressDetails: (profileData as any).original_address_details || profileData.originalAddress?.details,
        originalAddressHousingType: (profileData as any).original_address_housing_type || profileData.originalAddress?.housingType,
        currentHousingType: (profileData as any).current_housing_type || profileData.currentHousing?.type,
        currentHousingIsSuitable: (profileData as any).current_housing_is_suitable_for_family_size || profileData.currentHousing?.isSuitableForFamilySize,
        currentHousingSanitaryFacilities: (profileData as any).current_housing_sanitary_facilities || profileData.currentHousing?.sanitaryFacilities,
        currentHousingWaterSource: (profileData as any).current_housing_water_source || profileData.currentHousing?.waterSource,
        currentHousingElectricityAccess: (profileData as any).current_housing_electricity_access || profileData.currentHousing?.electricityAccess,
        currentHousingGovernorate: (profileData as any).current_housing_governorate || profileData.currentHousing?.governorate,
        currentHousingRegion: (profileData as any).current_housing_region || profileData.currentHousing?.region,
        currentHousingLandmark: (profileData as any).current_housing_landmark || profileData.currentHousing?.landmark,
        currentHousingSharingStatus: (profileData as any).current_housing_sharing_status || profileData.currentHousing?.sharingStatus,
        currentHousingDetailedType: (profileData as any).current_housing_detailed_type || profileData.currentHousing?.detailedType,
        currentHousingFurnished: (profileData as any).current_housing_furnished || profileData.currentHousing?.furnished
      };

      setDp(flatData);
    } catch (err: any) {
      console.error('[DPPortal] Error loading DP:', err);
      setToast({ message: err.message || 'فشل تحميل بيانات العائلة', type: 'error' });
    }
  };

  const loadFamilyMembers = async () => {
    try {
      const members = await beneficiaryService.getFamilyMembers(profileId);
      setFamilyMembers(members);
    } catch (err: any) {
      console.error('[DPPortal] Error loading family members:', err);
      setFamilyMembers([]);
    }
  };

  const loadTabData = async (tab: string) => {
    if (loadedTabs.has(tab)) return;

    // Get familyId from token
    const currentUser = sessionService.getCurrentUser();
    const familyId = currentUser?.familyId || profileId;

    // Set loading state for this tab
    setTabLoadingStates(prev => ({ ...prev, [tab]: true }));

    try {
      console.log(`[DPPortal] Loading data for tab: ${tab}, familyId: ${familyId}`);
      
      switch (tab) {
        case 'emergency':
          const emergencyData = await beneficiaryService.getEmergencyReports(familyId);
          console.log(`[DPPortal] Loaded ${emergencyData.length} emergency reports`);
          setEmergencyReports(emergencyData);
          break;
        case 'updates':
          const updatesData = await beneficiaryService.getUpdateRequests(familyId);
          console.log(`[DPPortal] Loaded ${updatesData.length} update requests`);
          setUpdateRequests(updatesData);
          break;
        case 'complaints':
          const complaintsData = await beneficiaryService.getComplaints(familyId);
          console.log(`[DPPortal] Loaded ${complaintsData.length} complaints`);
          setComplaints(complaintsData);
          break;
      }
      setLoadedTabs(prev => new Set(prev).add(tab));
    } catch (err: any) {
      console.error(`[DPPortal] Error loading ${tab} data:`, err);
      console.error(`[DPPortal] Error details:`, err.message);
      console.error(`[DPPortal] User context:`, {
        profileId,
        familyId,
        currentUser: sessionService.getCurrentUser()
      });
      setToast({ 
        message: `فشل تحميل بيانات ${tab}. يرجى التأكد من اتصالك بالإنترنت والمحاولة مرة أخرى.`, 
        type: 'error' 
      });
    } finally {
      // Clear loading state for this tab
      setTabLoadingStates(prev => ({ ...prev, [tab]: false }));
    }
  };

  const getFullName = (profile: DPProfileExtended | null): string => {
    if (!profile) return 'مستفيد';
    if (profile.headFirstName && profile.headFatherName && profile.headGrandfatherName && profile.headFamilyName) {
      return `${profile.headFirstName} ${profile.headFatherName} ${profile.headGrandfatherName} ${profile.headFamilyName}`;
    }
    return profile.headOfFamily || 'مستفيد';
  };

  // Tab loading states
  const [tabLoadingStates, setTabLoadingStates] = useState<Record<string, boolean>>({
    emergency: false,
    updates: false,
    complaints: false
  });

  const tabs = [
    { id: 'basic' as const, label: 'البيانات الأساسية', icon: (
      <svg className="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
      </svg>
    )},
    { id: 'family' as const, label: 'أفراد الأسرة', icon: (
      <svg className="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
      </svg>
    )},
    { id: 'housing' as const, label: 'السكن', icon: (
      <svg className="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
      </svg>
    )},
    { id: 'health' as const, label: 'الصحة', icon: (
      <svg className="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
      </svg>
    )},
    { id: 'spouse' as const, label: 'الزوج/الزوجة', icon: (
      <svg className="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
      </svg>
    )},
    { id: 'documents' as const, label: 'المستندات', icon: (
      <svg className="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
      </svg>
    )},
    { id: 'emergency' as const, label: 'البلاغات الطارئة', icon: (
      <svg className="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
      </svg>
    )},
    { id: 'updates' as const, label: 'طلبات التحديث', icon: (
      <svg className="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
      </svg>
    )},
    { id: 'complaints' as const, label: 'الشكاوى', icon: (
      <svg className="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
